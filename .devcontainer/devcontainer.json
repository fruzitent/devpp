{
  "$help": "https://containers.dev/implementors/json_reference",
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.schema.json",
  "customizations": {
    "vscode": {
      "extensions": [
        "docker.docker",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "FelixZeller.markdown-oxide",
        "mads-hartmann.bash-ide-vscode",
        "mkhl.shfmt",
        "ms-azuretools.vscode-docker",
        "timonwong.shellcheck"
      ],
      "settings": {
        "shellcheck.customArgs": ["-x"]
      }
    }
  },
  "features": {
    // @see: https://github.com/devcontainers-extra/features/pkgs/container/features/shfmt/versions
    "ghcr.io/devcontainers-extra/features/shfmt:1.0.2": {
      // @see: https://github.com/mvdan/sh/releases
      "version": "3.12.0"
    },
    // @see: https://github.com/devcontainers/features/pkgs/container/features/docker-in-docker/versions
    "ghcr.io/devcontainers/features/docker-in-docker:2.12.4": {
      // @see: https://packages.microsoft.com/ubuntu/24.04/prod/pool/main/m/moby-cli
      "version": "28.3.3"
    },
    // @see: https://github.com/devcontainers/features/pkgs/container/features/rust/versions
    "ghcr.io/devcontainers/features/rust:1.5.0": {
      // @see: https://github.com/rust-lang/rust/releases
      "version": "1.89.0"
    }
  },
  // @see: https://mcr.microsoft.com/artifact/mar/devcontainers/base/tags
  "image": "mcr.microsoft.com/devcontainers/base:2.0.4-ubuntu-24.04@sha256:ad92cae7c25cafb1e7bb5aa7520b81be85fac022ea92e404b94a11127631fae3",
  "runArgs": ["--security-opt=label=disable"],
  "remoteUser": "root",
  "updateRemoteUserUID": false
}
